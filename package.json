{
  "name": "switch-ts",
  "version": "3.0.0",
  "description": "Switch-case with support for complex conditions for TypeScript",
  "keywords": [
    "case",
    "default",
    "is",
    "switch",
    "typescript",
    "when"
  ],
  "homepage": "https://github.com/seijikohara/switch-ts#readme",
  "bugs": {
    "url": "https://github.com/seijikohara/switch-ts/issues"
  },
  "license": "MIT",
  "author": "Seiji Kohara <sage.0118@gmail.com> (https://github.com/seijikohara)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seijikohara/switch-ts.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "check:package": "node scripts/check-package.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "deps:update": "taze -w && pnpm install",
    "deps:check": "taze",
    "prepare": "lefthook install || exit 0",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.5",
    "@vitest/coverage-v8": "^4.1.10",
    "lefthook": "^2.1.10",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "taze": "^19.14.1",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.11.0",
      "onFail": "download"
    }
  },
  "packageManager": "pnpm@11.11.0"
}
